@page "/"

<PageTitle>DesliderClaude — Swipe. Rank. Play.</PageTitle>

<section class="hero">
    <h1 class="hero-title">
        <span class="dice" aria-hidden="true">🎲</span>Deslider<span class="line-2">Claude.</span>
    </h1>
    <span class="hero-tag">swipe · rank · play</span>
    <p class="hero-lede">
        The async way your friend group decides which boardgame gets played tonight —
        no more forty-five minutes of <em>"so… what do you wanna play?"</em> while the pizza gets cold.
    </p>
</section>

<div class="form-card">
    <form method="post" @formname="gotonight" @onsubmit="GoToNight">
        <AntiforgeryToken />
        <label for="share-code">Got a share code?</label>
        <input id="share-code" name="Form.ShareCode" value="@(Form?.ShareCode)" placeholder="autumn-frog-1234" autocomplete="off" autocapitalize="off" spellcheck="false" required />
        <div class="btn-row">
            <button type="submit" class="btn btn-primary">Jump in →</button>
        </div>
    </form>
</div>

<hr />

<p class="subtle">
    <strong>No code yet?</strong> F5 the Aspire AppHost, run the
    <em>Reset &amp; seed sample data</em> command on the <span class="mono">migrations</span> resource, then
    try <a href="/night/sample-night">the sample Game Night</a>.
</p>

@code {
    [SupplyParameterFromForm] public GoForm? Form { get; set; }
    [Inject] public NavigationManager Nav { get; set; } = default!;

    private void GoToNight()
    {
        var code = Form?.ShareCode?.Trim();
        if (!string.IsNullOrEmpty(code))
        {
            Nav.NavigateTo($"/night/{Uri.EscapeDataString(code)}");
        }
    }

    public sealed class GoForm
    {
        public string ShareCode { get; set; } = string.Empty;
    }
}
