@page "/admin/nights/{ShareCode}"
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@inject IGameNightService GameNights
@inject IAdminService AdminSvc
@inject NavigationManager Nav

<PageTitle>Admin · @(_night?.Name ?? ShareCode)</PageTitle>

@if (_night is null)
{
    <h1>Not found.</h1>
    <p><a href="/admin">← Back to admin</a></p>
}
else
{
    <section class="hero">
        <span class="kicker kicker-gold">Admin · Night</span>
        <h1 class="hero-title">@_night.Name</h1>
        <p class="hero-lede">
            <a class="admin-row-sub" href="/admin">← All nights</a> ·
            <a class="admin-row-sub" href="/night/@ShareCode">voter</a> ·
            <a class="admin-row-sub" href="/night/@ShareCode/winner">winner</a>
            @if (_night.IsClosed)
            {
                <span class="nights-badge closed" style="margin-left: 8px;">Closed</span>
            }
            else
            {
                <span class="nights-badge warn" style="margin-left: 8px;">Open</span>
            }
        </p>
    </section>

    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="text-danger">@_error</p>
    }

    <h2 class="kicker" style="margin-top: var(--s-5);">Voters (@_voters.Count)</h2>
    @if (_voters.Count == 0)
    {
        <p class="subtle">No one has joined this night yet.</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Callsign</th>
                    <th>Account</th>
                    <th class="right">Swipes</th>
                    <th class="right">Yes</th>
                    <th class="right">No</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in _voters)
                {
                    <tr>
                        <td>@v.DisplayName</td>
                        <td>
                            @if (v.Username is not null)
                            {
                                <span class="nights-badge voter">@v.Username</span>
                            }
                            else
                            {
                                <span class="subtle">anon</span>
                            }
                        </td>
                        <td class="right">@v.SwipeCount</td>
                        <td class="right"><span class="yes">+@v.YesCount</span></td>
                        <td class="right"><span class="no">−@v.NoCount</span></td>
                        <td>
                            <form method="post" @formname="@($"del-voter-{v.Id}")" @onsubmit="() => DeleteVoterAsync(v.Id)">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn-ghost btn-sm"
                                        onclick="return confirm('Remove voter “@v.DisplayName”? Their swipes are deleted. This can\'t be undone.');">✕</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public string ShareCode { get; set; } = string.Empty;

    private GameNight? _night;
    private IReadOnlyList<AdminVoterRow> _voters = Array.Empty<AdminVoterRow>();
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _night = await GameNights.GetByShareCodeAsync(ShareCode);
        if (_night is null) return;
        _voters = await AdminSvc.ListVotersForNightAsync(_night.Id);
    }

    private async Task DeleteVoterAsync(Guid voterId)
    {
        _error = null;
        try
        {
            await AdminSvc.DeleteVoterAsync(voterId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        Nav.NavigateTo($"/admin/nights/{ShareCode}");
    }
}
