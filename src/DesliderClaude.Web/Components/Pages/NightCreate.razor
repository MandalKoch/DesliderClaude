@page "/create"
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IGameNightService GameNights
@inject IBggImportService Bgg
@inject INightNameGenerator NightNames
@inject NavigationManager Nav

<PageTitle>Create Game Night — DesliderClaude</PageTitle>

<section class="hero">
    <span class="kicker">New game night</span>
    <h1 class="hero-title">Set the table.</h1>
    <p class="hero-lede">
        Start empty. Add games one by one, or pull in a whole BGG library.
        Filters narrow the BGG list — games you added by hand always stay visible.
    </p>
</section>

<div class="form-card">
    <form method="post" @formname="create-night" @onsubmit="HandleAsync">
        <AntiforgeryToken />

        <label for="night-name">Night name</label>
        <input id="night-name" name="Form.Name" value="@(string.IsNullOrEmpty(Form?.Name) ? _defaultName : Form!.Name)"
               maxlength="200" placeholder="Friday boardgames" autocomplete="off" required autofocus />

        <label for="target-date">Target date <span class="subtle">(optional)</span></label>
        <input id="target-date" name="Form.TargetDate" value="@(string.IsNullOrEmpty(Form?.TargetDate) ? _defaultDate : Form!.TargetDate)" type="date" />

        <hr />

        <fieldset class="fieldset">
            <legend>Add games</legend>

            <label for="add-text">Add a single game</label>
            <div class="inline-row">
                <input id="add-text" name="Form.NewTextGame" value="@Form?.NewTextGame" maxlength="200"
                       placeholder="e.g. Terraforming Mars" />
                <button type="submit" name="Form.Action" value="add-text" class="btn btn-ghost">+ Add</button>
            </div>

            @if (_imports.Count > 0)
            {
                <label for="add-import" style="margin-top: var(--s-4);">Add a BGG library</label>
                <div class="inline-row">
                    <select id="add-import" name="Form.ImportToAdd">
                        <option value="">Pick a library…</option>
                        @foreach (var imp in _imports)
                        {
                            <option value="@imp.Id">@imp.Name — @imp.GameCount games</option>
                        }
                    </select>
                    <button type="submit" name="Form.Action" value="add-import" class="btn btn-ghost">+ Add all</button>
                </div>
                <p class="subtle" style="font-size: 0.75rem; margin-top: 4px;">
                    Duplicates (same BGG game already in the table) are skipped.
                </p>
            }
            else
            {
                <p class="subtle" style="margin-top: var(--s-3);">
                    No BGG libraries yet. <a href="/account/libraries">Import a geeklist →</a>
                </p>
            }
        </fieldset>

        <fieldset class="fieldset">
            <legend>Filter BGG games <span class="subtle">(applies on add — hand-added games always stay)</span></legend>
            <div class="filter-grid">
                <div>
                    <label for="f-rec">Recommended for N players</label>
                    <input id="f-rec" name="Form.RecommendedFor" type="number" min="1" max="20" value="@Form?.RecommendedFor" placeholder="e.g. 4" />
                </div>
                <div>
                    <label for="f-players">Player count <span class="subtle">(min / max)</span></label>
                    <div class="inline-row">
                        <input id="f-players" name="Form.MinPlayers" type="number" min="1" max="99" value="@Form?.MinPlayers" placeholder="min" />
                        <input name="Form.MaxPlayers" type="number" min="1" max="99" value="@Form?.MaxPlayers" placeholder="max" />
                    </div>
                </div>
                <div>
                    <label for="f-time">Play time min <span class="subtle">(min / max)</span></label>
                    <div class="inline-row">
                        <input id="f-time" name="Form.MinPlayTime" type="number" min="0" max="999" value="@Form?.MinPlayTime" placeholder="min" />
                        <input name="Form.MaxPlayTime" type="number" min="0" max="999" value="@Form?.MaxPlayTime" placeholder="max" />
                    </div>
                </div>
            </div>
            <div class="btn-row" style="margin-top: var(--s-3);">
                <button type="submit" name="Form.Action" value="filter" class="btn btn-ghost btn-sm">Apply filters</button>
                <button type="submit" name="Form.Action" value="clear-filters" class="btn btn-ghost btn-sm">Clear</button>
            </div>
        </fieldset>

        <div class="candidate-toolbar">
            <span class="candidate-count">
                <strong>@_selectedVisibleCount</strong> / @_visibleCount selected
                @if (_candidates.Count != _visibleCount)
                {
                    <span class="subtle">(@(_candidates.Count - _visibleCount) hidden by filters)</span>
                }
            </span>
            <div class="btn-row">
                <button type="submit" name="Form.Action" value="select-all" class="btn btn-ghost btn-sm" disabled="@(_visibleCount == 0)">Select all visible</button>
                <button type="submit" name="Form.Action" value="deselect-all" class="btn btn-ghost btn-sm" disabled="@(_visibleCount == 0)">Deselect all visible</button>
            </div>
        </div>

        @if (_candidates.Count == 0)
        {
            <p class="empty">Nothing here yet. Add a game above or pull in a BGG library.</p>
        }
        else
        {
            <ul class="candidate-list">
                @for (var i = 0; i < _candidates.Count; i++)
                {
                    var c = _candidates[i];
                    var visible = IsVisible(c);
                    var rowClass = (_selected[i], visible, c.IsManual) switch
                    {
                        (true, true, true) => "is-selected is-manual",
                        (true, true, false) => "is-selected",
                        (false, true, _) => "is-unselected",
                        _ => "is-hidden"
                    };
                    <li class="candidate-row @rowClass" hidden="@(!visible)">
                        <label class="checkbox-row">
                            <input type="checkbox" name="Form.SelectedIndexes" value="@i" checked="@_selected[i]" />
                            @if (!string.IsNullOrEmpty(c.ThumbnailUrl))
                            {
                                <img class="candidate-thumb" src="@c.ThumbnailUrl" alt="" referrerpolicy="no-referrer" loading="lazy" />
                            }
                            <span class="candidate-main">
                                <span class="candidate-name">
                                    @c.Name
                                    @if (c.IsManual)
                                    {
                                        <span class="candidate-badge">manual</span>
                                    }
                                </span>
                                @if (!c.IsManual)
                                {
                                    <span class="candidate-meta">
                                        @if (c.MinPlayers is not null || c.MaxPlayers is not null)
                                        {
                                            <span>@(FormatRange(c.MinPlayers, c.MaxPlayers)) players</span>
                                        }
                                        @if (c.MinPlayTime is not null || c.MaxPlayTime is not null)
                                        {
                                            <span>· @(FormatRange(c.MinPlayTime, c.MaxPlayTime)) min</span>
                                        }
                                        @if (c.RecommendedFor.Count > 0)
                                        {
                                            <span>· rec @string.Join(",", c.RecommendedFor)</span>
                                        }
                                    </span>
                                }
                            </span>
                        </label>
                        <button type="submit" name="Form.RemoveIndex" value="@i" class="btn btn-ghost btn-sm" title="Remove from list">✕</button>

                        @* State carried across every POST. *@
                        <input type="hidden" name="Form.CandNames" value="@c.Name" />
                        <input type="hidden" name="Form.CandBggIds" value="@c.BggGameId" />
                        <input type="hidden" name="Form.CandImages" value="@(c.ImageUrl ?? string.Empty)" />
                        <input type="hidden" name="Form.CandThumbs" value="@(c.ThumbnailUrl ?? string.Empty)" />
                        <input type="hidden" name="Form.CandManuals" value="@(c.IsManual ? "1" : "0")" />
                        <input type="hidden" name="Form.CandMinP" value="@(c.MinPlayers?.ToString() ?? string.Empty)" />
                        <input type="hidden" name="Form.CandMaxP" value="@(c.MaxPlayers?.ToString() ?? string.Empty)" />
                        <input type="hidden" name="Form.CandMinT" value="@(c.MinPlayTime?.ToString() ?? string.Empty)" />
                        <input type="hidden" name="Form.CandMaxT" value="@(c.MaxPlayTime?.ToString() ?? string.Empty)" />
                        <input type="hidden" name="Form.CandRecs" value="@string.Join(",", c.RecommendedFor)" />
                    </li>
                }
            </ul>
        }

        <div class="btn-row" style="margin-top: var(--s-5);">
            <a class="btn btn-ghost" href="/">← Cancel</a>
            <button type="submit" name="Form.Action" value="create" class="btn btn-primary" disabled="@(_candidates.Count(ToKeep) < 2)">
                Create night →
            </button>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="text-danger">@_error</p>
    }
    @if (!string.IsNullOrEmpty(_notice))
    {
        <p class="text-ok">@_notice</p>
    }
</div>

@code {
    [CascadingParameter] public HttpContext? HttpContext { get; set; }
    [CascadingParameter] public Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }
    [SupplyParameterFromForm] public CreateFormModel? Form { get; set; }

    private IReadOnlyList<BggImportView> _imports = Array.Empty<BggImportView>();
    private List<Candidate> _candidates = new();
    private List<bool> _selected = new();
    private int _visibleCount;
    private int _selectedVisibleCount;
    private string? _error;
    private string? _notice;
    private string _defaultName = string.Empty;
    private string _defaultDate = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _defaultName = NightNames.Generate();
        _defaultDate = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");

        var uid = await GetUserIdAsync();
        if (uid is not null)
        {
            _imports = await Bgg.ListForUserAsync(uid.Value);
        }

        RehydrateCandidatesFromForm();
        RecountVisibility();
    }

    private async Task HandleAsync()
    {
        _error = null;
        _notice = null;
        var uid = await GetUserIdAsync();
        if (uid is null) return;

        // Row-level remove takes precedence over any Form.Action.
        if (!string.IsNullOrEmpty(Form?.RemoveIndex) && int.TryParse(Form.RemoveIndex, out var ri)
            && ri >= 0 && ri < _candidates.Count)
        {
            _candidates.RemoveAt(ri);
            _selected.RemoveAt(ri);
            RecountVisibility();
            return;
        }

        switch (Form?.Action)
        {
            case "add-text":
                AddManual(Form.NewTextGame);
                if (Form is not null) Form.NewTextGame = string.Empty;
                break;
            case "add-import":
                if (Guid.TryParse(Form?.ImportToAdd, out var importId))
                {
                    await AddImportAsync(uid.Value, importId);
                    if (Form is not null) Form.ImportToAdd = string.Empty;
                }
                break;
            case "select-all":
                SetVisibleSelection(true);
                break;
            case "deselect-all":
                SetVisibleSelection(false);
                break;
            case "clear-filters":
                if (Form is not null)
                {
                    Form.MinPlayers = Form.MaxPlayers = Form.MinPlayTime = Form.MaxPlayTime = Form.RecommendedFor = string.Empty;
                }
                break;
            case "filter":
                ApplyFiltersInPlace();
                break;
            case "create":
                await CreateAsync(uid.Value);
                return;
        }

        RecountVisibility();
    }

    private void AddManual(string? text)
    {
        var names = (text ?? string.Empty)
            .Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (names.Count == 0)
        {
            _error = "Type a game name first.";
            return;
        }

        var existing = _candidates.Select(c => c.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var added = 0;
        foreach (var n in names)
        {
            if (existing.Contains(n)) continue;
            _candidates.Add(new Candidate(n, 0, null, null, true, null, null, null, null, Array.Empty<int>()));
            _selected.Add(true);
            existing.Add(n);
            added++;
        }

        _notice = added == 0
            ? "Already on the list."
            : added == 1 ? "Added 1 game." : $"Added {added} games.";
    }

    private async Task AddImportAsync(Guid userId, Guid importId)
    {
        var games = await Bgg.ListCandidatesAsync(userId, new[] { importId });
        if (games.Count == 0)
        {
            _error = "That library has no games to import.";
            return;
        }

        var knownBgg = _candidates.Where(c => c.BggGameId > 0).Select(c => c.BggGameId).ToHashSet();
        var added = 0;
        var skippedByFilter = 0;
        foreach (var g in games)
        {
            if (knownBgg.Contains(g.BggGameId)) continue;
            var recs = g.RecommendedPlayerCounts
                .Where(v => v.Kind != BggPlayerCountKind.NotRecommended)
                .Select(v => v.Count)
                .Distinct()
                .OrderBy(n => n)
                .ToList();

            var candidate = new Candidate(
                g.Name, g.BggGameId, g.ImageUrl, g.ThumbnailUrl,
                IsManual: false,
                g.MinPlayers, g.MaxPlayers, g.MinPlayTimeMinutes, g.MaxPlayTimeMinutes,
                recs);

            // Active filters apply at add time too — no point loading a 200-game
            // library into the form when the user only wants 4-player games.
            if (!IsVisible(candidate))
            {
                skippedByFilter++;
                continue;
            }

            _candidates.Add(candidate);
            _selected.Add(true);
            knownBgg.Add(g.BggGameId);
            added++;
        }

        if (added == 0 && skippedByFilter > 0)
        {
            _notice = $"No games matched the filter ({skippedByFilter} skipped). Loosen the filter and try again.";
        }
        else if (added == 0)
        {
            _notice = "Every game in that library is already on the list.";
        }
        else
        {
            var tail = skippedByFilter > 0 ? $" ({skippedByFilter} skipped by filter)" : "";
            _notice = added == 1 ? $"Added 1 game.{tail}" : $"Added {added} games.{tail}";
        }
    }

    private void ApplyFiltersInPlace()
    {
        // Filtering is destructive: non-matching BGG candidates leave the list
        // entirely. Manual rows always survive (per product rule). Survivors
        // are auto-selected — the user just said "I want exactly these".
        var keep = new List<Candidate>(_candidates.Count);
        var keepSelected = new List<bool>(_candidates.Count);
        var dropped = 0;
        for (var i = 0; i < _candidates.Count; i++)
        {
            if (IsVisible(_candidates[i]))
            {
                keep.Add(_candidates[i]);
                keepSelected.Add(true);
            }
            else
            {
                dropped++;
            }
        }
        _candidates = keep;
        _selected = keepSelected;
        if (dropped > 0)
        {
            _notice = dropped == 1 ? "Removed 1 game that didn't match." : $"Removed {dropped} games that didn't match.";
        }
    }

    private void SetVisibleSelection(bool value)
    {
        for (var i = 0; i < _candidates.Count; i++)
        {
            if (IsVisible(_candidates[i])) _selected[i] = value;
        }
    }

    private async Task CreateAsync(Guid userId)
    {
        var name = Form?.Name?.Trim();
        if (string.IsNullOrEmpty(name))
        {
            _error = "Give the night a name.";
            return;
        }

        var chosen = new List<GameCandidate>();
        for (var i = 0; i < _candidates.Count; i++)
        {
            if (!_selected[i]) continue;
            var c = _candidates[i];
            chosen.Add(new GameCandidate(c.Name, c.BggGameId == 0 ? null : c.BggGameId, c.ImageUrl, c.ThumbnailUrl));
        }

        chosen = chosen
            .GroupBy(c => c.Name.Trim(), StringComparer.OrdinalIgnoreCase)
            .Select(g => g.First())
            .ToList();

        if (chosen.Count < 2)
        {
            _error = "Pick at least two games — otherwise there's nothing to swipe.";
            return;
        }

        DateOnly? targetDate = null;
        if (!string.IsNullOrWhiteSpace(Form?.TargetDate) && DateOnly.TryParse(Form.TargetDate, out var parsed))
        {
            targetDate = parsed;
        }

        var night = await GameNights.CreateAsync(name, targetDate, chosen, userId);
        Nav.NavigateTo($"/night/{night.ShareCode}/host");
    }

    private bool IsVisible(Candidate c)
    {
        if (c.IsManual) return true; // Always show manual rows — per product rule.
        if (Form is null) return true;

        if (int.TryParse(Form.MinPlayers, out var minP) && minP > 0)
            if (c.MaxPlayers is null || c.MaxPlayers < minP) return false;

        if (int.TryParse(Form.MaxPlayers, out var maxP) && maxP > 0)
            if (c.MinPlayers is null || c.MinPlayers > maxP) return false;

        if (int.TryParse(Form.MinPlayTime, out var minT) && minT > 0)
            if (c.MaxPlayTime is null || c.MaxPlayTime < minT) return false;

        if (int.TryParse(Form.MaxPlayTime, out var maxT) && maxT > 0)
            if (c.MinPlayTime is null || c.MinPlayTime > maxT) return false;

        if (int.TryParse(Form.RecommendedFor, out var recFor) && recFor > 0)
            if (!c.RecommendedFor.Contains(recFor)) return false;

        return true;
    }

    private bool ToKeep(Candidate c)
    {
        var i = _candidates.IndexOf(c);
        return i >= 0 && _selected[i];
    }

    private void RecountVisibility()
    {
        _visibleCount = 0;
        _selectedVisibleCount = 0;
        for (var i = 0; i < _candidates.Count; i++)
        {
            if (!IsVisible(_candidates[i])) continue;
            _visibleCount++;
            if (_selected[i]) _selectedVisibleCount++;
        }
    }

    private void RehydrateCandidatesFromForm()
    {
        if (Form is null) return;

        var names = Form.CandNames ?? Array.Empty<string>();
        var bggIds = Form.CandBggIds ?? Array.Empty<string>();
        var images = Form.CandImages ?? Array.Empty<string>();
        var thumbs = Form.CandThumbs ?? Array.Empty<string>();
        var manuals = Form.CandManuals ?? Array.Empty<string>();
        var minP = Form.CandMinP ?? Array.Empty<string>();
        var maxP = Form.CandMaxP ?? Array.Empty<string>();
        var minT = Form.CandMinT ?? Array.Empty<string>();
        var maxT = Form.CandMaxT ?? Array.Empty<string>();
        var recs = Form.CandRecs ?? Array.Empty<string>();

        var n = names.Length;
        _candidates = new List<Candidate>(n);
        _selected = new List<bool>(n);
        var selectedSet = (Form.SelectedIndexes ?? Array.Empty<string>())
            .Select(s => int.TryParse(s, out var i) ? i : -1)
            .ToHashSet();

        for (var i = 0; i < n; i++)
        {
            _candidates.Add(new Candidate(
                Name: names[i],
                BggGameId: i < bggIds.Length && int.TryParse(bggIds[i], out var id) ? id : 0,
                ImageUrl: i < images.Length && !string.IsNullOrEmpty(images[i]) ? images[i] : null,
                ThumbnailUrl: i < thumbs.Length && !string.IsNullOrEmpty(thumbs[i]) ? thumbs[i] : null,
                IsManual: i < manuals.Length && manuals[i] == "1",
                MinPlayers: i < minP.Length && int.TryParse(minP[i], out var a) ? a : null,
                MaxPlayers: i < maxP.Length && int.TryParse(maxP[i], out var b) ? b : null,
                MinPlayTime: i < minT.Length && int.TryParse(minT[i], out var c) ? c : null,
                MaxPlayTime: i < maxT.Length && int.TryParse(maxT[i], out var d) ? d : null,
                RecommendedFor: i < recs.Length
                    ? recs[i].Split(',', StringSplitOptions.RemoveEmptyEntries)
                        .Select(s => int.TryParse(s, out var r) ? r : 0)
                        .Where(r => r > 0)
                        .ToArray()
                    : Array.Empty<int>()));
            _selected.Add(selectedSet.Contains(i));
        }
    }

    private async Task<Guid?> GetUserIdAsync()
    {
        if (AuthState is null) return null;
        var state = await AuthState;
        return state.User.GetUserId();
    }

    private static string FormatRange(int? min, int? max)
    {
        if (min is null && max is null) return "?";
        if (min == max) return min!.Value.ToString();
        if (min is null) return $"≤{max}";
        if (max is null) return $"≥{min}";
        return $"{min}–{max}";
    }

    public sealed record Candidate(
        string Name,
        int BggGameId,
        string? ImageUrl,
        string? ThumbnailUrl,
        bool IsManual,
        int? MinPlayers,
        int? MaxPlayers,
        int? MinPlayTime,
        int? MaxPlayTime,
        IReadOnlyList<int> RecommendedFor);

    public sealed class CreateFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string TargetDate { get; set; } = string.Empty;
        public string Action { get; set; } = string.Empty;
        public string RemoveIndex { get; set; } = string.Empty;

        public string NewTextGame { get; set; } = string.Empty;
        public string ImportToAdd { get; set; } = string.Empty;

        public string MinPlayers { get; set; } = string.Empty;
        public string MaxPlayers { get; set; } = string.Empty;
        public string MinPlayTime { get; set; } = string.Empty;
        public string MaxPlayTime { get; set; } = string.Empty;
        public string RecommendedFor { get; set; } = string.Empty;

        public string[]? SelectedIndexes { get; set; }
        public string[]? CandNames { get; set; }
        public string[]? CandBggIds { get; set; }
        public string[]? CandImages { get; set; }
        public string[]? CandThumbs { get; set; }
        public string[]? CandManuals { get; set; }
        public string[]? CandMinP { get; set; }
        public string[]? CandMaxP { get; set; }
        public string[]? CandMinT { get; set; }
        public string[]? CandMaxT { get; set; }
        public string[]? CandRecs { get; set; }
    }
}
