@page "/night/{ShareCode}"
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@inject IGameNightService GameNights
@inject IVotingService Voting
@inject NavigationManager Nav

<PageTitle>@(_night?.Name ?? "Game Night") — DesliderClaude</PageTitle>

@if (_night is null)
{
    <h1>Not found.</h1>
    <p>That Game Night link doesn't match anything. Double-check the URL.</p>
    <p><a href="/">← Back home</a></p>
}
else if (_night.IsClosed)
{
    <h1>@_night.Name</h1>
    <div class="notice notice-closed">
        <p><strong>Voting closed.</strong> The host locked in the pick.</p>
    </div>
    <p><a href="/night/@ShareCode/winner">See tonight's pick →</a></p>
}
else
{
    <span class="kicker">Game Night · @_night.Games.Count candidates</span>
    <h1>@_night.Name</h1>
    <p class="subtle">Pick a callsign to start swiping.</p>

    <div class="form-card">
        <form method="post" @formname="join" @onsubmit="JoinAsync">
            <AntiforgeryToken />
            <label for="display-name">Your callsign</label>
            <input id="display-name" name="Form.DisplayName" value="@(Form?.DisplayName ?? _prefill)" maxlength="40" autocomplete="nickname" required autofocus />
            <div class="btn-row">
                <button type="submit" class="btn btn-primary">Enter the deck →</button>
            </div>
        </form>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="text-danger">@_error</p>
    }
}

@code {
    [Parameter] public string ShareCode { get; set; } = string.Empty;
    [CascadingParameter] public HttpContext? HttpContext { get; set; }
    [CascadingParameter] public Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }
    [SupplyParameterFromForm] public JoinFormModel? Form { get; set; }

    private GameNight? _night;
    private string? _error;
    private string _prefill = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _night = await GameNights.GetByShareCodeAsync(ShareCode);
        if (_night is null || HttpContext is null || _night.IsClosed) return;

        var voterCookieName = VoterCookie.Name(ShareCode);
        var existingVoterToken = HttpContext.Request.Cookies[voterCookieName];

        // 1. Already joined this night? Jump straight to swiping.
        if (!string.IsNullOrEmpty(existingVoterToken))
        {
            var progress = await Voting.GetProgressAsync(existingVoterToken);
            if (progress?.GameNightId == _night.Id)
            {
                Nav.NavigateTo($"/night/{ShareCode}/swipe");
                return;
            }
        }

        // 2. Signed-in voter? Auto-join with their username — no prompt needed.
        if (AuthState is not null)
        {
            var state = await AuthState;
            var username = state.User.GetUsername();
            var userId = state.User.GetUserId();
            if (!string.IsNullOrEmpty(username) && userId is { } uid)
            {
                var token = EnsureVoterToken(voterCookieName, existingVoterToken);
                try
                {
                    await Voting.JoinAsync(_night.Id, username, token, uid);
                    Nav.NavigateTo($"/night/{ShareCode}/swipe");
                    return;
                }
                catch (InvalidOperationException)
                {
                    // Fall through to the manual form.
                }
                _prefill = username;
            }
        }
    }

    private string EnsureVoterToken(string cookieName, string? existing)
    {
        if (!string.IsNullOrEmpty(existing)) return existing;
        var token = VoterCookie.NewToken();
        HttpContext!.Response.Cookies.Append(cookieName, token, VoterCookie.Options);
        return token;
    }

    private async Task JoinAsync()
    {
        if (_night is null || _night.IsClosed || HttpContext is null) return;

        var name = Form?.DisplayName?.Trim();
        if (string.IsNullOrEmpty(name))
        {
            _error = "Please enter a name.";
            return;
        }

        var voterCookieName = VoterCookie.Name(ShareCode);
        var voterToken = EnsureVoterToken(voterCookieName, HttpContext.Request.Cookies[voterCookieName]);

        Guid? userId = null;
        if (AuthState is not null)
        {
            var state = await AuthState;
            userId = state.User.GetUserId();
        }

        try
        {
            await Voting.JoinAsync(_night.Id, name, voterToken, userId);
        }
        catch (InvalidOperationException ex)
        {
            _error = ex.Message;
            return;
        }

        Nav.NavigateTo($"/night/{ShareCode}/swipe");
    }

    public sealed class JoinFormModel
    {
        public string DisplayName { get; set; } = string.Empty;
    }
}
