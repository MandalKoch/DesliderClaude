@page "/night/{ShareCode}/ranking"
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@inject IGameNightService GameNights
@inject IVotingService Voting

<HeadContent>
    @* Crude live-ranking: full page refresh every 5 seconds. Will be replaced with SignalR in v1. *@
    @if (_night is not null && !_night.IsClosed)
    {
        <meta http-equiv="refresh" content="5" />
    }
</HeadContent>

<PageTitle>Ranking — @(_night?.Name ?? "Game Night")</PageTitle>

@if (_night is null)
{
    <h1>Not found</h1>
    <p><a href="/">Back home</a></p>
}
else
{
    <h1>@_night.Name</h1>
    <p>
        @if (_night.IsClosed)
        {
            <span><strong>Final ranking</strong> — voting closed @_night.ClosedAt?.ToString("f").</span>
        }
        else
        {
            <span>Live ranking — updates every few seconds.</span>
        }
    </p>

    @if (_ranking.Count == 0)
    {
        <p>No games on the list yet.</p>
    }
    else
    {
        <ol class="ranking">
            @foreach (var row in _ranking)
            {
                <li>
                    <span class="name">@row.Name</span>
                    <span class="votes">👍 @row.YesCount · 👎 @row.NoCount</span>
                </li>
            }
        </ol>
    }

    @if (!_night.IsClosed)
    {
        <p><a href="/night/@ShareCode/swipe">Back to swiping →</a></p>
    }
}

@code {
    [Parameter] public string ShareCode { get; set; } = string.Empty;

    private GameNight? _night;
    private IReadOnlyList<GameRanking> _ranking = Array.Empty<GameRanking>();

    protected override async Task OnInitializedAsync()
    {
        _night = await GameNights.GetByShareCodeAsync(ShareCode);
        if (_night is null) return;
        _ranking = await Voting.GetRankingAsync(_night.Id);
    }
}

<style>
    ol.ranking { list-style: none; padding: 0; }
    ol.ranking li {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #eee;
        counter-increment: rank;
    }
    ol.ranking li::before {
        content: counter(rank) ".";
        font-weight: bold;
        color: #5C2D91;
        margin-right: 0.75rem;
        min-width: 1.5rem;
    }
    ol.ranking li:first-child { background: #fff8e1; }
    ol.ranking .name { flex-grow: 1; }
    ol.ranking .votes { color: #666; white-space: nowrap; }
</style>
