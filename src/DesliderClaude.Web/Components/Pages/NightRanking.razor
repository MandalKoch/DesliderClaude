@page "/night/{ShareCode}/ranking"
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@inject IGameNightService GameNights
@inject IVotingService Voting

<HeadContent>
    @* Crude live-ranking: full page refresh every 5 seconds. Will be replaced with SignalR in v1. *@
    @if (_night is not null && !_night.IsClosed)
    {
        <meta http-equiv="refresh" content="5" />
    }
</HeadContent>

<PageTitle>Ranking — @(_night?.Name ?? "Game Night")</PageTitle>

@if (_night is null)
{
    <h1>Not found.</h1>
    <p><a href="/">← Back home</a></p>
}
else
{
    <div class="ranking-head">
        <div>
            <span class="mono">Ranking</span>
            <h1>@_night.Name</h1>
        </div>
        @if (_night.IsClosed)
        {
            <span class="ranking-status">Final · closed @(_night.ClosedAt?.ToString("MMM d, HH:mm"))</span>
        }
        else
        {
            <span class="ranking-status live">Live · refreshing</span>
        }
    </div>

    @if (_ranking.Count == 0)
    {
        <div class="empty">No games on the list yet.</div>
    }
    else
    {
        <ol class="ranking-list">
            @for (int i = 0; i < _ranking.Count; i++)
            {
                var row = _ranking[i];
                <li class="@(i == 0 ? "winner" : null)">
                    <span class="ranking-name">@row.Name</span>
                    <span class="ranking-votes">
                        <span class="yes">👍 @row.YesCount</span>
                        <span class="dot">·</span>
                        <span class="no">👎 @row.NoCount</span>
                    </span>
                </li>
            }
        </ol>
    }

    @if (!_night.IsClosed)
    {
        <div class="btn-row">
            <a class="btn" href="/night/@ShareCode/swipe">← Back to swiping</a>
        </div>
    }
}

@code {
    [Parameter] public string ShareCode { get; set; } = string.Empty;

    private GameNight? _night;
    private IReadOnlyList<GameRanking> _ranking = Array.Empty<GameRanking>();

    protected override async Task OnInitializedAsync()
    {
        _night = await GameNights.GetByShareCodeAsync(ShareCode);
        if (_night is null) return;
        _ranking = await Voting.GetRankingAsync(_night.Id);
    }
}
