@page "/night/{ShareCode}/swipe"
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@inject IGameNightService GameNights
@inject IVotingService Voting
@inject NavigationManager Nav

<PageTitle>Swipe — @(_night?.Name ?? "Game Night")</PageTitle>

@if (_night is null)
{
    <h1>Not found</h1>
    <p><a href="/">Back home</a></p>
}
else if (_voterToken is null)
{
    <h1>@_night.Name</h1>
    <p>You need to join before you can swipe.</p>
    <p><a href="/night/@ShareCode">Enter your name →</a></p>
}
else if (_currentGame is null)
{
    <h1>All done, @(_progress?.DisplayName).</h1>
    <p>You've swiped on every game in @_night.Name.</p>
    <p><a href="/night/@ShareCode/ranking">See the live ranking →</a></p>
}
else
{
    <p><small>@(_swipedCount + 1) of @_night.Games.Count</small></p>

    <div class="swipe-card">
        <h1>@_currentGame.Name</h1>
    </div>

    <form method="post" @formname="swipe" @onsubmit="RecordAsync">
        <AntiforgeryToken />
        <input type="hidden" name="Form.GameId" value="@_currentGame.Id" />
        <button type="submit" name="Form.Yes" value="false" class="swipe-no">👎 No</button>
        <button type="submit" name="Form.Yes" value="true" class="swipe-yes">👍 Yes</button>
    </form>

    <p><a href="/night/@ShareCode/ranking">Peek at the current ranking →</a></p>
}

@code {
    [Parameter] public string ShareCode { get; set; } = string.Empty;
    [CascadingParameter] public HttpContext? HttpContext { get; set; }
    [SupplyParameterFromForm] public SwipeFormModel? Form { get; set; }

    private GameNight? _night;
    private string? _voterToken;
    private VoterProgress? _progress;
    private Game? _currentGame;
    private int _swipedCount;

    protected override async Task OnInitializedAsync()
    {
        _night = await GameNights.GetByShareCodeAsync(ShareCode);
        if (_night is null) return;

        if (_night.IsClosed)
        {
            Nav.NavigateTo($"/night/{ShareCode}/ranking");
            return;
        }

        _voterToken = HttpContext?.Request.Cookies[VoterCookie.Name(ShareCode)];
        if (string.IsNullOrEmpty(_voterToken)) return;

        _progress = await Voting.GetProgressAsync(_voterToken);
        if (_progress is null || _progress.GameNightId != _night.Id)
        {
            _voterToken = null;
            return;
        }

        if (Form is { GameId: var gameId } && gameId != Guid.Empty && _currentGame is null)
        {
            // Form POST just arrived — record this swipe before picking the next game.
            await Voting.RecordSwipeAsync(_voterToken, gameId, Form.Yes);
            _progress = await Voting.GetProgressAsync(_voterToken);
        }

        var sortedGames = _night.Games.OrderBy(g => g.Id).ToList();
        _swipedCount = _progress!.Swipes.Count;
        _currentGame = sortedGames.FirstOrDefault(g => !_progress.Swipes.ContainsKey(g.Id));
    }

    private Task RecordAsync() => Task.CompletedTask; // all logic runs in OnInitializedAsync after the POST rerenders the page

    public sealed class SwipeFormModel
    {
        public Guid GameId { get; set; }
        public bool Yes { get; set; }
    }
}

<style>
    .swipe-card {
        border: 2px solid #5C2D91;
        border-radius: 16px;
        padding: 3rem 1.5rem;
        text-align: center;
        margin: 1.5rem 0;
        background: linear-gradient(135deg, #f8f5ff 0%, #ffffff 100%);
    }
    .swipe-card h1 { margin: 0; font-size: 2.5rem; }
    .swipe-no, .swipe-yes {
        font-size: 1.5rem;
        padding: 1rem 2rem;
        border-radius: 12px;
        border: none;
        cursor: pointer;
        margin: 0 0.5rem;
    }
    .swipe-no { background: #fde8e8; color: #a11; }
    .swipe-yes { background: #e8fde8; color: #171; }
</style>
