@page "/night/{ShareCode}/swipe"
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@inject IGameNightService GameNights
@inject IVotingService Voting
@inject NavigationManager Nav

<PageTitle>Swipe — @(_night?.Name ?? "Game Night")</PageTitle>

@if (_night is null)
{
    <h1>Not found.</h1>
    <p><a href="/">← Back home</a></p>
}
else if (_voterToken is null)
{
    <h1>@_night.Name</h1>
    <div class="notice">
        <p><strong>You need to join before you can swipe.</strong></p>
        <p><a href="/night/@ShareCode">Enter your name →</a></p>
    </div>
}
else if (_currentGame is null)
{
    @* Only reachable when the night has zero games on it. *@
    <h1>@_night.Name</h1>
    <div class="notice">
        <p><strong>No games on this night yet.</strong></p>
        <p>Ask the host to add some candidate games, then come back.</p>
    </div>
}
else
{
    <div class="swipe-wrap">
        <div class="swipe-progress">
            @if (_unvoted > 0)
            {
                <span class="swipe-progress-label">
                    <strong>@(_night.Games.Count - _unvoted)</strong> / @_night.Games.Count discovered
                </span>
            }
            else
            {
                <span class="swipe-progress-label">
                    <strong>@_swipeCount</strong> swipes · all explored
                </span>
            }
            <span class="swipe-progress-bar">
                <span class="swipe-progress-fill" style="transform: scaleX(@_progressRatio)"></span>
            </span>
        </div>

        <div class="swipe-stage">
            <article class="swipe-card" data-swipe-card>
                <div class="swipe-card-corners"></div>
                <div class="swipe-card-label">@_cardLabel</div>
                <h1 class="swipe-card-title">@_currentGame.Name</h1>
                <span class="swipe-stamp swipe-stamp-yes" data-swipe-overlay-yes aria-hidden="true">Deploy</span>
                <span class="swipe-stamp swipe-stamp-no" data-swipe-overlay-no aria-hidden="true">Pass</span>
            </article>
            <p class="swipe-hint" aria-hidden="true">Drag the card · or use the buttons · swipes update live</p>
        </div>

        <form method="post" @formname="swipe" @onsubmit="RecordAsync" data-swipe-form>
            <AntiforgeryToken />
            <input type="hidden" name="Form.GameId" value="@_currentGame.Id" />
            <div class="swipe-actions">
                <button type="submit" name="Form.Yes" value="false" class="swipe-btn swipe-btn-no" data-swipe-no>
                    <span class="emoji" aria-hidden="true">✕</span>Pass
                </button>
                <button type="submit" name="Form.Yes" value="true" class="swipe-btn swipe-btn-yes" data-swipe-yes>
                    <span class="emoji" aria-hidden="true">✓</span>Deploy
                </button>
            </div>
        </form>

        <div class="swipe-footlinks">
            <a href="/night/@ShareCode/ranking">Peek at the ranking</a>
        </div>
    </div>
}

@code {
    [Parameter] public string ShareCode { get; set; } = string.Empty;
    [CascadingParameter] public HttpContext? HttpContext { get; set; }
    [SupplyParameterFromForm] public SwipeFormModel? Form { get; set; }

    private GameNight? _night;
    private string? _voterToken;
    private VoterProgress? _progress;
    private Game? _currentGame;
    private int _swipeCount;
    private int _unvoted;
    private string _progressRatio = "0";
    private string _cardLabel = "candidate";

    protected override async Task OnInitializedAsync()
    {
        _night = await GameNights.GetByShareCodeAsync(ShareCode);
        if (_night is null) return;

        if (_night.IsClosed)
        {
            Nav.NavigateTo($"/night/{ShareCode}/winner");
            return;
        }

        _voterToken = HttpContext?.Request.Cookies[VoterCookie.Name(ShareCode)];
        if (string.IsNullOrEmpty(_voterToken)) return;

        _progress = await Voting.GetProgressAsync(_voterToken);
        if (_progress is null || _progress.GameNightId != _night.Id)
        {
            _voterToken = null;
            return;
        }

        Guid? justSwipedGameId = null;
        if (Form is { GameId: var gameId } && gameId != Guid.Empty)
        {
            // Form POST just arrived — upsert this swipe before picking the next game.
            await Voting.RecordSwipeAsync(_voterToken, gameId, Form.Yes);
            _progress = await Voting.GetProgressAsync(_voterToken);
            justSwipedGameId = gameId;
        }

        _swipeCount = _progress!.Swipes.Count;
        _unvoted = Math.Max(0, _night.Games.Count - _progress.Swipes.Count);
        _currentGame = await Voting.PickNextGameAsync(_voterToken, justSwipedGameId);

        if (_currentGame is not null)
        {
            var gameWasSwiped = _progress.Swipes.ContainsKey(_currentGame.Id);
            _cardLabel = gameWasSwiped ? "re-roll" : "candidate";
        }

        if (_night.Games.Count > 0)
        {
            var ratio = (double)(_night.Games.Count - _unvoted) / _night.Games.Count;
            _progressRatio = ratio.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        }
    }

    private Task RecordAsync() => Task.CompletedTask; // all logic runs in OnInitializedAsync after the POST rerenders the page

    public sealed class SwipeFormModel
    {
        public Guid GameId { get; set; }
        public bool Yes { get; set; }
    }
}
