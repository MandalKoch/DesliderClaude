@page "/night/{ShareCode}/swipe"
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@inject IGameNightService GameNights
@inject IVotingService Voting
@inject NavigationManager Nav

<PageTitle>Swipe — @(_night?.Name ?? "Game Night")</PageTitle>

@if (_night is null)
{
    <h1>Not found.</h1>
    <p><a href="/">← Back home</a></p>
}
else if (_voterToken is null)
{
    <h1>@_night.Name</h1>
    <div class="notice">
        <p><strong>You need to join before you can swipe.</strong></p>
        <p><a href="/night/@ShareCode">Enter your name →</a></p>
    </div>
}
else if (_currentGame is null)
{
    @* Either no games on the night or every candidate has been voted on.
       "All voted" → we redirect to /votes in OnInitializedAsync, so this
       branch only ever shows for zero-games nights. *@
    <h1>@_night.Name</h1>
    <div class="notice">
        <p><strong>No games on this night yet.</strong></p>
        <p>Ask the host to add some candidate games, then come back.</p>
    </div>
}
else
{
    <div class="swipe-wrap">
        @if (!string.IsNullOrEmpty(_restoreUrl))
        {
            <details class="restore-panel">
                <summary>Bookmark this link to return later</summary>
                <p class="subtle">Clearing cookies or switching browsers would otherwise lose your votes. This link is your key — keep it private.</p>
                <input type="text" readonly value="@_restoreUrl" onclick="this.select();" />
                <div class="btn-row">
                    <button type="button" class="btn btn-ghost btn-sm"
                            onclick="navigator.clipboard.writeText('@_restoreUrl');this.textContent='Copied ✓';setTimeout(()=>this.textContent='Copy link',1500);">
                        Copy link
                    </button>
                </div>
            </details>
        }

        <div class="swipe-progress">
            <span class="swipe-progress-label">
                <strong>@_swipeCount</strong> / @_night.Games.Count voted
            </span>
            <span class="swipe-progress-bar">
                <span class="swipe-progress-fill" style="transform: scaleX(@_progressRatio)"></span>
            </span>
        </div>

        <div class="swipe-stage">
            <article class="swipe-card @(string.IsNullOrEmpty(_currentGame.ImageUrl) ? "swipe-card-noart" : "swipe-card-withart")" data-swipe-card>
                <div class="swipe-card-corners"></div>
                @if (!string.IsNullOrEmpty(_currentGame.ImageUrl))
                {
                    @* Hotlinked from BGG's CDN. Referrer stripped so BGG doesn't see a per-user signal.
                       Decorative — accessible name comes from the title below. *@
                    <img class="swipe-card-art" src="@_currentGame.ImageUrl" alt=""
                         referrerpolicy="no-referrer" loading="eager" decoding="async"
                         draggable="false" />
                }
                <div class="swipe-card-label">candidate</div>
                <h1 class="swipe-card-title">@_currentGame.Name</h1>
                <div class="swipe-stamp swipe-stamp-yes" data-swipe-overlay-yes aria-hidden="true">
                    <span class="swipe-stamp-icon">✓</span>
                    <span class="swipe-stamp-label">Play</span>
                </div>
                <div class="swipe-stamp swipe-stamp-no" data-swipe-overlay-no aria-hidden="true">
                    <span class="swipe-stamp-icon">✕</span>
                    <span class="swipe-stamp-label">Pass</span>
                </div>
            </article>
            <p class="swipe-hint" aria-hidden="true">Drag the card · or use the buttons · swipes update live</p>
        </div>

        <form method="post" @formname="swipe" @onsubmit="RecordAsync" data-swipe-form>
            <AntiforgeryToken />
            <input type="hidden" name="Form.GameId" value="@_currentGame.Id" />
            <div class="swipe-actions">
                <button type="submit" name="Form.Yes" value="true" class="swipe-btn swipe-btn-yes" data-swipe-yes>
                    <span class="emoji" aria-hidden="true">✓</span>Play
                </button>
                <button type="submit" name="Form.Yes" value="false" class="swipe-btn swipe-btn-no" data-swipe-no>
                    <span class="emoji" aria-hidden="true">✕</span>Pass
                </button>
            </div>
        </form>

        <div class="swipe-footlinks">
            <a href="/night/@ShareCode/votes">My votes</a>
            <a href="/night/@ShareCode/winner">Peek at the pick</a>
            @if (_isHost)
            {
                <a href="/night/@ShareCode/host">Host dashboard</a>
            }
        </div>

        @if (_others.Count > 0)
        {
            var totalGames = _night.Games.Count;
            <details class="voters-strip">
                <summary>@_others.Count voter@(_others.Count == 1 ? "" : "s") in this night</summary>
                <ul class="voters-strip-list">
                    @foreach (var v in _others)
                    {
                        <li>
                            <span class="voters-strip-name">@v.DisplayName</span>
                            <span class="voters-strip-count">@v.SwipesCast / @totalGames</span>
                        </li>
                    }
                </ul>
            </details>
        }
    </div>
}

@code {
    [Parameter] public string ShareCode { get; set; } = string.Empty;
    [CascadingParameter] public HttpContext? HttpContext { get; set; }
    [CascadingParameter] public Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState>? AuthState { get; set; }
    [SupplyParameterFromForm] public SwipeFormModel? Form { get; set; }

    private GameNight? _night;
    private string? _voterToken;
    private VoterProgress? _progress;
    private Game? _currentGame;
    private int _swipeCount;
    private string _progressRatio = "0";
    private bool _isHost;
    private string? _restoreUrl;
    private IReadOnlyList<VoterPublicStatus> _others = Array.Empty<VoterPublicStatus>();

    protected override async Task OnInitializedAsync()
    {
        _night = await GameNights.GetByShareCodeAsync(ShareCode);
        if (_night is null) return;

        if (AuthState is not null)
        {
            var state = await AuthState;
            var uid = state.User.GetUserId();
            _isHost = uid is not null && _night.CreatedByUserId == uid;
        }

        if (_night.IsClosed)
        {
            Nav.NavigateTo(_isHost
                ? $"/night/{ShareCode}/host"
                : $"/night/{ShareCode}/winner");
            return;
        }

        _voterToken = HttpContext?.Request.Cookies[VoterCookie.Name(ShareCode)];
        if (string.IsNullOrEmpty(_voterToken)) return;

        _progress = await Voting.GetProgressAsync(_voterToken);
        if (_progress is null || _progress.GameNightId != _night.Id)
        {
            _voterToken = null;
            return;
        }

        _swipeCount = _progress.Swipes.Count;
        _currentGame = await Voting.PickNextGameAsync(_voterToken);

        if (_progress.UserId is null && HttpContext is not null)
        {
            _restoreUrl = $"{HttpContext.Request.Scheme}://{HttpContext.Request.Host}/night/{ShareCode}/restore/{_voterToken}";
        }

        // Every candidate already voted → bounce to the votes management page.
        // (Handler also navigates there on the last swipe; this covers returning
        // visitors who reach /swipe after the fact.)
        if (_currentGame is null && _night.Games.Count > 0 && _swipeCount >= _night.Games.Count)
        {
            Nav.NavigateTo($"/night/{ShareCode}/votes");
            return;
        }

        if (_night.Games.Count > 0)
        {
            var ratio = (double)_swipeCount / _night.Games.Count;
            _progressRatio = ratio.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        }

        _others = await Voting.ListPublicVoterStatusesAsync(_night.Id);
    }

    private async Task RecordAsync()
    {
        // Keep mutations out of OnInitializedAsync — Blazor SSR's form-handler lookup
        // happens during render, so removing the form (via state change in Init) would
        // break the POST handshake. Instead: record here, then redirect.
        if (_voterToken is null || _night is null || _night.IsClosed) return;
        if (Form is null || Form.GameId == Guid.Empty) return;

        await Voting.RecordSwipeAsync(_voterToken, Form.GameId, Form.Yes);

        var next = await Voting.PickNextGameAsync(_voterToken, Form.GameId);
        Nav.NavigateTo(next is null
            ? $"/night/{ShareCode}/votes"
            : $"/night/{ShareCode}/swipe");
    }

    public sealed class SwipeFormModel
    {
        public Guid GameId { get; set; }
        public bool Yes { get; set; }
    }
}
