@page "/night/{ShareCode}/host"
@using System.Globalization
@using DesliderClaude.Core.Models
@using DesliderClaude.Core.Services
@inject IGameNightService GameNights
@inject IVotingService Voting
@inject NavigationManager Nav

<PageTitle>Host · @(_night?.Name ?? "Game Night")</PageTitle>

@if (_night is null)
{
    <h1>Not found.</h1>
    <p>That Game Night link doesn't match anything.</p>
    <p><a href="/">← Back home</a></p>
}
else if (!_isHost)
{
    <h1>Not your night.</h1>
    <p class="subtle">
        You're signed in as a different user than the one who created <strong>@_night.Name</strong>.
        Sign in with the host's account to manage this night.
    </p>
    <div class="btn-row">
        <a class="btn" href="/night/@ShareCode">Voter →</a>
        <a class="btn btn-ghost" href="/night/@ShareCode/winner">See the pick →</a>
    </div>
}
else
{
    <div class="ranking-head">
        <div>
            <span class="kicker kicker-gold">You're hosting</span>
            <h1>@_night.Name</h1>
            @if (_night.TargetDate is { } date)
            {
                <p class="subtle">Target date · @date.ToString("dddd, MMM d")</p>
            }
        </div>
        @if (_night.IsClosed)
        {
            <span class="ranking-status">Closed · @(_night.ClosedAt?.ToString("MMM d, HH:mm"))</span>
        }
        else
        {
            <span class="ranking-status live">Open</span>
        }
    </div>

    <div class="form-card">
        <label for="share-url">Share link</label>
        <input id="share-url" type="text" readonly value="@_shareUrl" onclick="this.select();" />
        <div class="btn-row">
            <button type="button" class="btn btn-cyan"
                    onclick="navigator.clipboard.writeText('@_shareUrl');this.textContent='Copied ✓';setTimeout(()=>this.textContent='Copy link',1500);">
                Copy link
            </button>
            <span class="subtle">Anyone with the link can swipe. No accounts.</span>
        </div>
    </div>

    <div class="host-stats">
        <div class="host-stat"><span class="host-stat-num">@_voterCount</span><span class="host-stat-label">voter@(_voterCount == 1 ? "" : "s")</span></div>
        <div class="host-stat"><span class="host-stat-num">@_night.Games.Count</span><span class="host-stat-label">games</span></div>
        <div class="host-stat"><span class="host-stat-num">@_totalSwipes</span><span class="host-stat-label">swipe@(_totalSwipes == 1 ? "" : "s")</span></div>
    </div>

    <div class="btn-row host-actions">
        <a class="btn btn-cyan" href="/night/@ShareCode">Vote as host →</a>
        <a class="btn btn-ghost" href="/night/@ShareCode/winner">Current pick →</a>
        @if (!_night.IsClosed)
        {
            <form method="post" @formname="close-night" @onsubmit="CloseAsync" class="host-close-form">
                <AntiforgeryToken />
                <button type="submit" class="btn btn-primary btn-close-vote">
                    <span class="emoji" aria-hidden="true">⏻</span> Close voting
                </button>
            </form>
        }
        else
        {
            <form method="post" @formname="reopen-night" @onsubmit="ReopenAsync" style="display: inline;">
                <AntiforgeryToken />
                <button type="submit" class="btn btn-ghost">Re-open voting</button>
            </form>
        }
    </div>

    <h2 class="kicker" style="margin-top: var(--s-6);">Voters</h2>
    <form method="post" @formname="voters" @onsubmit="VotersFormAsync">
        <AntiforgeryToken />
        @if (_voters.Count == 0)
        {
            <p class="subtle">Nobody's joined yet. Share the link, or pre-name a voter below.</p>
        }
        else
        {
            var gameCount = _night.Games.Count;
            <ul class="voter-list">
                @foreach (var v in _voters)
                {
                    var pct = gameCount == 0 ? 0 : (int)Math.Round(100.0 * v.SwipesCast / gameCount);
                    var inviteUrl = $"{_baseUrl}/night/{ShareCode}/invite/{v.VoterToken}";
                    <li class="voter-row @(v.SwipesCast == 0 ? "voter-pending" : null)">
                        <div class="voter-meta">
                            <span class="voter-name">@v.DisplayName</span>
                            <span class="voter-progress-text">
                                @v.SwipesCast / @gameCount
                                @if (v.LastSwipeAt is { } last)
                                {
                                    <span class="subtle"> · last swipe @FormatRelative(last)</span>
                                }
                                else
                                {
                                    <span class="subtle"> · hasn't started</span>
                                }
                            </span>
                        </div>
                        <progress class="voter-progress" max="@gameCount" value="@v.SwipesCast" aria-label="@pct%"></progress>
                        @if (!_night.IsClosed)
                        {
                            <div class="voter-invite-btn">
                                <button type="button" class="btn btn-ghost btn-sm"
                                        onclick="navigator.clipboard.writeText('@inviteUrl');this.textContent='Copied ✓';setTimeout(()=>this.textContent='Copy invite',1500);">
                                    Copy invite
                                </button>
                                <button type="submit" name="Form.RemoveVoterId" value="@v.VoterId"
                                        class="btn btn-ghost btn-sm voter-remove-btn"
                                        title="Remove @v.DisplayName and all their votes"
                                        onclick="return confirm('Remove @v.DisplayName and delete all their votes?');">
                                    ✕
                                </button>
                            </div>
                        }
                    </li>
                }
            </ul>
        }

        @if (!_night.IsClosed)
        {
            <div class="form-inline" style="margin-top: var(--s-3);">
                <label for="invite-name" class="visually-hidden">Invite by name</label>
                <input id="invite-name" name="Form.InviteName" value="@Form?.InviteName" maxlength="40" placeholder="Pre-name a voter (e.g. Alice)" />
                <button type="submit" name="Form.Action" value="invite" class="btn btn-ghost">+ Add invite</button>
            </div>
            @if (!string.IsNullOrEmpty(_lastInviteUrl))
            {
                <p class="text-ok" style="margin-top: var(--s-2);">
                    Invite for <strong>@_lastInviteName</strong> ready —
                    <a href="@_lastInviteUrl">@_lastInviteUrl</a>
                </p>
            }
        }
    </form>

    @if (_ranking.Count > 0)
    {
        <h2 class="kicker" style="margin-top: var(--s-6);">Live standings</h2>
        <ol class="ranking-list">
            @for (int i = 0; i < _ranking.Count; i++)
            {
                var row = _ranking[i];
                <li class="@(i == 0 ? "winner" : null)">
                    @if (i == 0)
                    {
                        <span class="winner-badge">@(_night.IsClosed ? "Final pick" : "Top pick")</span>
                    }
                    <span class="ranking-name">@row.Name</span>
                    <span class="ranking-votes">
                        <span class="yes">+@row.YesCount</span>
                        <span class="no">−@row.NoCount</span>
                    </span>
                </li>
            }
        </ol>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="text-danger">@_error</p>
    }
}

@code {
    [Parameter] public string ShareCode { get; set; } = string.Empty;
    [CascadingParameter] public Task<AuthenticationState>? AuthState { get; set; }
    [CascadingParameter] public HttpContext? HttpContext { get; set; }
    [SupplyParameterFromForm] public InviteFormModel? Form { get; set; }

    private GameNight? _night;
    private bool _isHost;
    private Guid? _currentUserId;
    private string _shareUrl = string.Empty;
    private string _baseUrl = string.Empty;
    private int _voterCount;
    private int _totalSwipes;
    private IReadOnlyList<GameRanking> _ranking = Array.Empty<GameRanking>();
    private IReadOnlyList<VoterStatus> _voters = Array.Empty<VoterStatus>();
    private string? _error;
    private string? _lastInviteUrl;
    private string? _lastInviteName;

    protected override async Task OnInitializedAsync()
    {
        _night = await GameNights.GetByShareCodeAsync(ShareCode);
        if (_night is null) return;

        if (AuthState is not null)
        {
            var state = await AuthState;
            _currentUserId = state.User.GetUserId();
        }

        _isHost = _currentUserId is { } uid
            && _night.CreatedByUserId is { } hostId
            && hostId == uid;
        if (!_isHost) return;

        _baseUrl = HttpContext is null
            ? string.Empty
            : $"{HttpContext.Request.Scheme}://{HttpContext.Request.Host}";
        _shareUrl = $"{_baseUrl}/night/{ShareCode}";
        _ranking = await Voting.GetRankingAsync(_night.Id);
        _voters = await Voting.ListVoterStatusesAsync(_night.Id);
        _voterCount = _voters.Count;
        _totalSwipes = _ranking.Sum(r => r.YesCount + r.NoCount);
    }

    private async Task VotersFormAsync()
    {
        _error = null;
        _lastInviteUrl = null;
        _lastInviteName = null;
        if (_night is null || !_isHost) return;

        // Per-voter remove takes precedence — the row's submit button posts the
        // VoterId, anything else is the invite-by-name action.
        if (Form?.RemoveVoterId is Guid removeId && removeId != Guid.Empty)
        {
            try
            {
                await Voting.RemoveVoterAsync(removeId, _night.Id);
            }
            catch (Exception ex)
            {
                _error = ex.Message;
            }
            await ReloadVotersAsync();
            return;
        }

        if (Form?.Action == "invite")
        {
            var name = Form.InviteName?.Trim();
            if (string.IsNullOrEmpty(name))
            {
                _error = "Type a name for the invite.";
                return;
            }
            try
            {
                var voter = await Voting.CreateInviteAsync(_night.Id, name);
                _lastInviteName = voter.DisplayName;
                _lastInviteUrl = $"{_baseUrl}/night/{ShareCode}/invite/{voter.VoterToken}";
                if (Form is not null) Form.InviteName = string.Empty;
                await ReloadVotersAsync();
            }
            catch (Exception ex)
            {
                _error = ex.Message;
            }
        }
    }

    private async Task ReloadVotersAsync()
    {
        if (_night is null) return;
        _voters = await Voting.ListVoterStatusesAsync(_night.Id);
        _voterCount = _voters.Count;
        _ranking = await Voting.GetRankingAsync(_night.Id);
        _totalSwipes = _ranking.Sum(r => r.YesCount + r.NoCount);
    }

    private static string FormatRelative(DateTimeOffset when)
    {
        var diff = DateTimeOffset.UtcNow - when;
        if (diff < TimeSpan.FromMinutes(1)) return "just now";
        if (diff < TimeSpan.FromHours(1)) return $"{(int)diff.TotalMinutes}m ago";
        if (diff < TimeSpan.FromDays(1)) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }

    public sealed class InviteFormModel
    {
        public string InviteName { get; set; } = string.Empty;
        public string Action { get; set; } = string.Empty;
        public Guid? RemoveVoterId { get; set; }
    }

    private async Task CloseAsync()
    {
        if (_night is null || _currentUserId is not { } uid) return;

        try
        {
            await GameNights.CloseAsync(_night.Id, uid);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            return;
        }

        Nav.NavigateTo($"/night/{ShareCode}/host");
    }

    private async Task ReopenAsync()
    {
        if (_night is null || _currentUserId is not { } uid) return;

        try
        {
            await GameNights.ReopenAsync(_night.Id, uid);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            return;
        }

        Nav.NavigateTo($"/night/{ShareCode}/host");
    }
}
