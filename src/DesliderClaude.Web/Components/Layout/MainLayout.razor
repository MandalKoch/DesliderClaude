@inherits LayoutComponentBase

<header class="app-header">
    <a class="app-brand" href="/">
        <svg class="hex" viewBox="0 0 26 30" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
                <linearGradient id="hexGrad" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#4fd1ff" />
                    <stop offset="100%" stop-color="#ffb443" />
                </linearGradient>
            </defs>
            <path d="M13 1.5 L24 7.5 L24 22.5 L13 28.5 L2 22.5 L2 7.5 Z" stroke="url(#hexGrad)" stroke-width="1.5" />
            <path d="M13 8 L18 11 L18 19 L13 22 L8 19 L8 11 Z" stroke="#4fd1ff" stroke-width="1" opacity="0.7" />
            <circle cx="13" cy="15" r="1.3" fill="#ffb443" />
        </svg>
        <span><span class="name">Deslider</span><span class="name-dim">Claude</span></span>
    </a>
    <nav class="app-nav">
        <AuthorizeView Roles="Admin">
            <a class="app-nav-link is-admin" href="/admin">Admin</a>
        </AuthorizeView>
        <AuthorizeView>
            <Authorized>
                <a class="app-nav-link is-signed-in" href="/account">
                    <svg class="app-nav-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="8" cy="5.5" r="2.75" stroke="currentColor" stroke-width="1.4" />
                        <path d="M2.5 13.5c0-2.5 2.5-4.25 5.5-4.25s5.5 1.75 5.5 4.25" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                    </svg>
                    <span>@context.User.Identity?.Name</span>
                </a>
            </Authorized>
            <NotAuthorized>
                <a class="app-nav-link" href="/signin">Sign in</a>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</header>

<main class="page">
    @Body
</main>

<footer class="footer-meta">
    <span>Friend-group party app</span>
    <span>Aspire · .NET 10</span>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    System error
    <a href="." class="reload">Reload</a>
    <span class="dismiss">✕</span>
</div>
